# Caddyfile
#
# To enable HTTPS (Let's Encrypt), replace ":80" with your hostname:
#   fabio.interviews.robots-inc.io
# Caddy will obtain a cert automatically when the A record is live.
#
# For the current phase (no DNS yet), plain HTTP on port 80.

:80 {
    reverse_proxy api:8000

    # Basic access log
    log {
        output stdout
        format json
    }
}
